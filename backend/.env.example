PORT=4000
NODE_ENV=development

# Supabase — récupérer dans Settings > API de ton projet Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...   # Service Role Key (ne jamais exposer côté client)

# JWT Secret — même valeur que dans Supabase > Settings > API > JWT Secret
JWT_SECRET=your-supabase-jwt-secret

# Email (Resend — gratuit jusqu'à 3000 mails/mois)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@mundiotravel.com

# Frontend URL (pour les liens dans les emails)
FRONTEND_URL=http://localhost:5173
